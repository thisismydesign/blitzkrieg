{
  "name": "blitzkrieg",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @blitzkrieg/web dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "pnpm --filter @blitzkrieg/web deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
