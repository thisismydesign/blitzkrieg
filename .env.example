# ─────────────────────────────────────────────────────────────────────────────
# Blitzkrieg environment variables — copy to `.env` and fill in.
#
# `.env` and every `.env.*` (except this template) are gitignored. For full
# local-stack development, put LOCAL values in `.env.local` (Vite loads it ahead
# of `.env`); `supabase start` prints the local API URL and keys.
#
# SECURITY: only SUPABASE_URL and SUPABASE_PUBLISHABLE_KEY are exposed to the
# browser (bundled by apps/web/vite.config.ts). NEVER expose the secret key or
# DB password to the client.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase — client-safe (exposed to the browser) ─────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# ── Supabase — server-only (edge functions, migrations, scripts) ────────────
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_JWKS_URL=https://YOUR-PROJECT-REF.supabase.co/auth/v1/.well-known/jwks.json

# ── Supabase CLI — linking + deploy (also set as GitHub Actions secrets) ────
# Personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
# Project ref = the subdomain of SUPABASE_URL (e.g. abcdefghijklmnop)
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF

# ── chess.com integration ───────────────────────────────────────────────────
# Contact string embedded in the User-Agent sent to the chess.com public API.
CHESSCOM_CONTACT=you@example.com

# ── Cloudflare Pages deploy (GitHub Actions secrets) ────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Standalone Docker Postgres (docker-compose.yml) ─────────────────────────
POSTGRES_PASSWORD=postgres
